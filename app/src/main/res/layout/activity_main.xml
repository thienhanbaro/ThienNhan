<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="16dp">

    <!-- Shizuku Status Pill -->
    <TextView
        android:id="@+id/tv_shizuku_status"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="@drawable/pill_shizuku"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:text="Shizuku: Đang kiểm tra..."
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Card thông tin thiết bị -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/grey"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_shizuku_status">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="@color/red" />
                <TextView
                    android:id="@+id/tv_device_name"
                    style="@style/infoText"
                    android:layout_marginStart="8dp"
                    android:text="Device: ..." />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:tint="@color/red" />
                <TextView
                    android:id="@+id/tv_device_model"
                    style="@style/infoText"
                    android:layout_marginStart="8dp"
                    android:text="ID Device: ..." />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:tint="@color/red" />
                <TextView
                    android:id="@+id/tv_android_version"
                    style="@style/infoText"
                    android:layout_marginStart="8dp"
                    android:text="Android version: ..." />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:tint="@color/red" />
                <TextView
                    android:id="@+id/tv_vulkan"
                    style="@style/infoText"
                    android:layout_marginStart="8dp"
                    android:text="Vulkan support: ..." />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Khu vực 2 nút -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/card_info">

        <!-- Nút Game-Booster -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_game_booster"
            style="@style/CustomToggleButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="GAME\nBOOSTER"
            app:icon="@android:drawable/ic_menu_compass"
            app:iconGravity="textStart" />

        <!-- Nút Touch Latency -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_touch_latency"
            style="@style/CustomToggleButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="TOUCH\nLATENCY"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconGravity="textStart" />
    </LinearLayout>

    <!-- Hướng dẫn ngắn -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bật nút để kích hoạt"
        android:textColor="#80FFFFFF"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btn_game_booster"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
